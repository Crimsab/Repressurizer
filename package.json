{
  "name": "repressurizer",
  "private": true,
  "version": "0.2.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "bun run i18n:check && tsc --noEmit && bun run --cwd packages/integration check",
    "integration:build": "bun run --cwd packages/integration build",
    "integration:rust:check": "cargo check --manifest-path packages/rust/Cargo.toml",
    "integration:rust:test": "cargo test --manifest-path packages/rust/Cargo.toml",
    "integration:rust:publish-dry-run": "cargo publish --dry-run --manifest-path packages/rust/Cargo.toml",
    "i18n:check": "bun scripts/i18n-check.ts",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "vitest run src packages/integration/test",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "html-to-image": "^1.11.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  }
}
